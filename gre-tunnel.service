[Unit]
Description=Controlled Egress GRE Tunnel
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/srv/GREX/gre-tunnel.sh
ExecStop=/srv/GREX/gre-tunnel-stop.sh
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
