# Example GRE Tunnel Configuration
# Copy this to /etc/gre-tunnel.conf and modify as needed

VPS_PUBLIC_IP=x.x.x.x
REMOTE_PUBLIC_IP=x.x.x.x
INTERNAL_SUBNETS=192.168.0.0/16,172.16.0.0/12
ENABLE_DNSMASQ=yes
DNS_SERVERS=1.1.1.1,8.8.8.8
ETH_INTERFACE=eth0

VPS_TUNNEL_IP=10.10.10.2/30
REMOTE_TUNNEL_IP=10.10.10.1
GRE_IF=grex
GRE_KEY=
GRE_MTU=1400
MSS_MODE=fixed
MSS_VALUE=1360
ENABLE_HARDENING=yes
ADMIN_IPS=x.x.x.x
ALLOW_ICMP=yes
ENABLE_EGRESS_FILTERING=no
BLOCK_SMTP_OUT=yes
BLOCK_PRIVATE_DESTINATIONS=yes
ENABLE_SYSCTL_HARDENING=yes
SYSCTL_PROFILE=safe
RP_FILTER=2
TCP_TIMESTAMPS=1
LOG_MARTIANS=yes
DISABLE_IPV6=no
NF_CONNTRACK_MAX=262144
ENABLE_FAIL2BAN=yes
FAIL2BAN_SSHD_ENABLED=true
FAIL2BAN_SSHD_PORT=22
FAIL2BAN_SSHD_MAXRETRY=3
FAIL2BAN_SSHD_FINDTIME=10m
FAIL2BAN_SSHD_BANTIME=1h
